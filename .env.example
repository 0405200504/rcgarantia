# ─────────────────────────────────────────────────────────────
#  RC Garantia — Variáveis de ambiente
# ─────────────────────────────────────────────────────────────
#  Copie para .env.local e preencha para usar Google Sheets.
#  Sem essas variáveis, o sistema usa armazenamento local (JSON).
# ─────────────────────────────────────────────────────────────

# ID da planilha (parte da URL: docs.google.com/spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEETS_SPREADSHEET_ID=

# E-mail do service account (ex: rc-garantia@projeto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Chave privada do service account (JSON → campo "private_key", com \n literal)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Segredo da sessão (mude em produção)
SESSION_SECRET=rc-garantia-segredo-local-dev-2026
