# ── OPÇÃO 1: Google Apps Script (RECOMENDADO — mais simples) ──────
# Siga as instruções em apps-script/Codigo.js
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_ID/exec
GOOGLE_APPS_SCRIPT_SECRET=rc-garantia-2026

# ── OPÇÃO 2: Google Sheets API direta (requer Google Cloud) ───────
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Sessão ────────────────────────────────────────────────────────
# Troque por uma string aleatória em produção
SESSION_SECRET=rc-garantia-segredo-local-dev-2026
